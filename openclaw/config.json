{
  "$schema": "https://docs.openclaw.ai/schema/config.json",
  "_comment": [
    "OpenClaw Configuration",
    "Location after deploy: ~/.openclaw/config.json (on MBA: sloppy@sloppy-mba.local)",
    "",
    "OpenClaw talks only to the local LiteLLM router on the MBA.",
    "Stable aliases: general, coder.",
    "Hidden cloud aliases remain available as hosted fallbacks."
  ],

  "models": {
    "providers": {
      "mba-litellm": {
        "baseUrl": "http://127.0.0.1:4000/v1",
        "apiKey": "litellm-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "general",
            "name": "LiteLLM general route",
            "reasoning": true,
            "contextWindow": 32768,
            "maxTokens": 4096
          },
          {
            "id": "coder",
            "name": "LiteLLM coder route",
            "reasoning": true,
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "general-cloud",
            "name": "LiteLLM hosted general fallback",
            "reasoning": true,
            "contextWindow": 32768,
            "maxTokens": 4096
          },
          {
            "id": "coder-cloud",
            "name": "LiteLLM hosted coder fallback",
            "reasoning": true,
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "mba-litellm/general",
        "fallbacks": [
          "mba-litellm/coder",
          "mba-litellm/general-cloud",
          "mba-litellm/coder-cloud"
        ]
      }
    }
  }
}
