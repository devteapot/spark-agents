# Ollama environment configuration for DGX Spark agent serving
# Source this file or add to /etc/environment or systemd override
#
# Usage:
#   source ollama.env && ollama serve
#
# Or create a systemd override:
#   sudo systemctl edit ollama
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0"
#   Environment="OLLAMA_NUM_PARALLEL=2"
#   Environment="OLLAMA_MAX_LOADED_MODELS=2"
#   Environment="OLLAMA_KV_CACHE_TYPE=q8_0"
#   Environment="OLLAMA_FLASH_ATTENTION=1"

# Listen on all interfaces so MBA agents can connect
OLLAMA_HOST=0.0.0.0

# Two concurrent slots — one per agent (Hermes + OpenClaw)
OLLAMA_NUM_PARALLEL=2

# Keep both models loaded simultaneously
OLLAMA_MAX_LOADED_MODELS=2

# Q8 KV cache — halves KV memory vs default f16, minimal quality loss
OLLAMA_KV_CACHE_TYPE=q8_0

# Enable flash attention for better memory efficiency
OLLAMA_FLASH_ATTENTION=1
